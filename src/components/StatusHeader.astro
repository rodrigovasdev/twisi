---
// Status Component
import TitleContainer from './TitleContainer.astro';
import StatusToggle from './StatusToggle.astro';
---

<div class="container status-container">
	<div class="status-header">
		<img src="isipisi.png">
	</div>
	<div >
		<StatusToggle />
	</div>
	<div class="viewer-count">
		<TitleContainer text="👥 1098 SEGUIDORES" />
	</div>
</div>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;600;700&display=swap');

    img{
        width:100%;
        max-height: 200px;
    }
	.container {
		background: white;
		border-radius: 16px;
		box-shadow: 0 4px 12px rgba(255, 105, 180, 0.1);
		overflow: hidden;
		display: flex;
		flex-direction: column;
        max-height: 100px;
	}

	/* Status Container - Full width at top */
	.status-container {
		grid-column: span 4;
		grid-row: span 1;
		background: linear-gradient(135deg, #ff69b4 0%, #ffb3d9ff 100%);
		color: white;
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 2rem;
		justify-content: space-around;
	}

	.status-header h2 {
		margin: 0 0 1rem 0;
		font-size: 1.2rem;
        text-align: left;
	}

	.status-indicator {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 1.5rem;
		font-weight: bold;
	}

	.status-text {
		font-family: 'Pixelify Sans', monospace;
		font-weight: 700;
	}

	.status-dot {
		width: 12px;
		height: 12px;
		background: #1fe01fff;
		border-radius: 50%;
		animation: pulse 1s infinite;
	}

	@keyframes pulse {
		20%, 100% { opacity: 1; }
		50% { opacity: 0.5; }
	}

	.viewer-count {
		font-size: 1.1rem;
		opacity: 0.9;
		font-family: 'Pixelify Sans', monospace;
		font-weight: 600;
	}
	@media (max-width: 700px) {
        .viewer-count {
			display: none;
		}
		.status-container {
			align-items: center;
			gap: 0;
		}
		img{	
			width:90%;
    	}
	}
	
</style>
