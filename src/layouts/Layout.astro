---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Twisi - Dashboard de Twitch" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Font Options: Pixelify Sans or Bungee -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400;600;700&family=Bungee&family=Rubik:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Change between 'Pixelify Sans' or 'Bungee' */
		--display-font: 'Bungee', monospace;
		/* --display-font: 'Bungee', cursive; */
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		padding: 0;
		font-family: 'Rubik', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
		background: linear-gradient(135deg, #ffeef8 0%, #e0f7ff 100%);
		min-height: 100vh;
	}

	h1, h2, h3, h4, h5, h6 {
		margin: 0;
		font-weight: 600;
	}

	p {
		margin: 0;
	}
</style>
